<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>View Images</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        /* Background gradient overlaid on the image */
       background-image: 
      
          linear-gradient(to bottom, #fb47009f, rgba(225, 59, 22, 0.747)), 
          url("./images/smilingbg.jpg");
        background-size: cover; /* Cover the whole area */
        background-position: center; /* Center the background image */
        padding: 20px;
      }
      .image-container {
        max-width: 800px;
        margin: 0 auto;
        background-color: white; /* Container background */
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        max-height: 600px; /* Limit height */
        overflow-y: scroll; /* Add scroll bar */
      }
      .image {
        margin-bottom: 20px;
      }
      .image img {
        max-width: 100%; /* Responsive image */
        border-radius: 8px;
      }
      .description {
        font-size: 0.9em; /* Adjust font size for description */
        color: #555;
      }
      h1 {
        text-align: center;
      }
      .filter-form {
        text-align: center;
        margin-bottom: 20px;
      }
    </style>
  </head>
  <body>
    <h1>Uploaded Images</h1>
    <div class="filter-form">
      <form action="/view-images" method="GET">
        <label for="date">Select Date:</label>
        <input type="date" id="date" name="date" required />
        <button type="submit">Filter</button>
      </form>
    </div>
    <div class="image-container">
      {{#each images}}
        <div class="image">
          <img src="/uploads/{{this.filename}}" alt="{{this.description}}" />
          <p class="description">{{this.description}}</p>
        </div>
      {{/each}}
    </div>
  </body>
</html>
